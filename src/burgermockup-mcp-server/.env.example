# --- burgermockup-mcp-server ------------------------------------------------
# Bind host: keep 127.0.0.1 for local loopback. On a public host bind 0.0.0.0 and
# set MCP_AUTH_TOKEN below (the Bearer gate then protects /mcp).
MCP_BIND_HOST=127.0.0.1
MCP_PORT=8100

# Shared Bearer token gating /mcp + mutation routes on public hosts (e.g. Railway).
# Leave EMPTY for local loopback/compose — the gate self-disables. The MCP client
# (open-webui) must send the same value. Generate: openssl rand -hex 32
MCP_AUTH_TOKEN=

# Base URL used in returned file links (set to the host-reachable address).
PUBLIC_FILES_BASE=http://127.0.0.1:8100

# Console log verbosity (DEBUG shows gate scores + scene-cache hits/misses).
LOG_LEVEL=INFO

# Storage directory for designs/mockups (UUID-keyed PNG files).
FILES_DIR=files

# BurgerPrints API key — ONLY needed to re-crawl the catalog
# (python -m server.catalog.crawl_catalog). Runtime serves from the committed
# catalog.json and never calls the BP API.
BP_API_KEY=

# Image generation (phase 03+): Gemini only.
GEMINI_API_KEY=
